{
  "mcpServers": {
    "sqlite": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite", "/tmp/sqlite.db"]
    },
    "zepto": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.zepto.co.in/mcp"],
      "timeout_ms": 60000
    },
    "swiggy-instamart": {
      "type": "http",
      "url": "https://mcp.swiggy.com/im",
      "timeout_ms": 60000
    },
    "swiggy-food": {
      "type": "http",
      "url": "https://mcp.swiggy.com/food",
      "timeout_ms": 60000
    },
    "swiggy-dineout": {
      "type": "http",
      "url": "https://mcp.swiggy.com/dineout",
      "timeout_ms": 60000
    }
  }
}
