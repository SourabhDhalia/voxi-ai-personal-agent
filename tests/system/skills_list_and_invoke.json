{
  "name": "skills-list-and-invoke",
  "offline_safe": true,
  "steps": [
    {
      "name": "list-textual-skills",
      "method": "list_skills",
      "params": {},
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "skills",
          "exists": true
        }
      ]
    },
    {
      "name": "toggle-skill-state",
      "method": "toggle_skill",
      "params": {
        "name": "git_helper",
        "enabled": false
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        },
        {
          "path": "name",
          "equals": "git_helper"
        },
        {
          "path": "enabled",
          "equals": false
        }
      ]
    }
  ]
}
