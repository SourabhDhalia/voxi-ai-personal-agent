{
  "name": "hooks-pre-tool-deny",
  "offline_safe": true,
  "steps": [
    {
      "name": "configure-deny-hook",
      "method": "set_hooks_config",
      "params": {
        "config": {
          "external_enabled": false,
          "timeout_ms": 5000,
          "rules": [
            {
              "event": "pre_tool",
              "matcher": "file_manager",
              "action": "deny"
            }
          ]
        }
      },
      "assertions": [
        {
          "path": "status",
          "equals": "ok"
        }
      ]
    },
    {
      "name": "try-executing-file-manager-denied",
      "method": "bridge_tool",
      "params": {
        "tool_name": "file_manager",
        "allowed_tools": ["file_manager"],
        "args": {
          "session_id": "hooks-test-session",
          "operation": "read",
          "path": "somefile.txt"
        }
      },
      "assertions": [
        {
          "path": "success",
          "equals": false
        },
        {
          "path": "error",
          "contains": "Blocked by pre_tool hook"
        }
      ]
    }
  ]
}
